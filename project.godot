config_version=5

[application]

config/name="Factolyth"
run/main_scene="uid://cdvo0srdwci2"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0.7919991, 0.79199916, 0.7919991, 1)
boot_splash/image="uid://bmdbdhjmemmo7"
config/icon="res://icon.svg"
config/main_scene="res://scenes/main.tscn"

[autoload]

SaveManager="*res://scripts/save_manager.gd"
ItemDB="*res://scripts/item_db.gd"
ItemRegistry="*res://scripts/item_registry.gd"

[display]

