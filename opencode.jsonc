{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "Você está desenvolvendo o jogo Factolyth (Godot 4.6 + GDScript). Siga rigorosamente as convenções do projeto descritas em INSTRUCOES_AI.md e nos agentes em .opencode/agents/. Todo código, comentários e commits em Português (Brasil)."
    }
  },
  "customCommands": [
    {
      "name": "revisar",
      "prompt": "Revise o código alterado nos arquivos. Analise bugs de performance, lógica e boas práticas Godot 4. Liste apenas os problemas encontrados.",
      "description": "Revisa o código alterado em busca de bugs e problemas de performance"
    },
    {
      "name": "testar",
      "prompt": "Execute o projeto no Godot para verificar se tudo funciona. Se não houver erro, informe que está OK.",
      "description": "Testa o projeto no Godot"
    },
    {
      "name": "convencoes",
      "prompt": "Verifique se todos os arquivos alterados seguem as convenções do projeto em INSTRUCOES_AI.md (snake_case, type hints, português, etc.). Liste apenas violações.",
      "description": "Verifica se o código segue as convenções do projeto"
    }
  ]
}
